<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Only include DataStore preferences for cloud backup and device transfer.
         Room database is intentionally omitted — restoring a DB across schema
         versions can corrupt data. Caffeine history is local-only by design. -->
    <cloud-backup>
        <include domain="sharedpref" path="." />
    </cloud-backup>

    <device-transfer>
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>